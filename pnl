import React, { useState, useMemo } from 'react';
import { 
  Plus, 
  Trash2, 
  Printer, 
  BookOpen, 
  FileText, 
  DollarSign, 
  Calendar,
  AlertCircle,
  ArrowUpRight,
  ArrowDownRight,
  Filter,
  CheckCircle2,
  FileSpreadsheet
} from 'lucide-react';

// Penetapan 4 Lejer Utama Sahaja
const LEDGERS = {
  jualan: { id: 'jualan', name: 'Lejer Jualan', type: 'Hasil', color: 'emerald', desc: 'Rekod semua hasil jualan produk atau perkhidmatan utama.' },
  belian: { id: 'belian', name: 'Lejer Belian', type: 'Kos Jualan', color: 'amber', desc: 'Rekod kos belian stok, bahan mentah, atau kos langsung jualan.' },
  hasil: { id: 'hasil', name: 'Lejer Hasil', type: 'Hasil', color: 'indigo', desc: 'Rekod pendapatan lain seperti komisen, dividen, atau subsidi.' },
  belanja: { id: 'belanja', name: 'Lejer Belanja', type: 'Belanja', color: 'rose', desc: 'Rekod kos operasi seperti sewa, gaji, bil air/elektrik, dan iklan.' }
};

export default function App() {
  // --- STATE UTAMA ---
  const [transactions, setTransactions] = useState([
    { id: 't1', date: '2026-07-01', ledgerId: 'jualan', description: 'Jualan runcit minggu pertama', amount: 3500.00 },
    { id: 't2', date: '2026-07-02', ledgerId: 'belian', description: 'Belian stok barang niaga', amount: 1200.00 },
    { id: 't3', date: '2026-07-03', ledgerId: 'belanja', description: 'Bayaran sewa kedai bulanan', amount: 1000.00 },
    { id: 't4', date: '2026-07-04', ledgerId: 'hasil', description: 'Komisen daripada jualan affiliate', amount: 450.00 },
    { id: 't5', date: '2026-07-05', ledgerId: 'belanja', description: 'Bil elektrik & internet', amount: 250.00 },
  ]);

  // State Borang Tambah Transaksi
  const [txDate, setTxDate] = useState(new Date().toISOString().split('T')[0]);
  const [txLedgerId, setTxLedgerId] = useState('jualan');
  const [txDesc, setTxDesc] = useState('');
  const [txAmount, setTxAmount] = useState('');

  // Penapis Paparan Lejer dalam Jadual (Semua vs Lejer Spesifik)
  const [selectedLedgerFilter, setSelectedLedgerFilter] = useState('semua');

  // Navigasi Tab Utama ('lejer' atau 'pnl')
  const [activeTab, setActiveTab] = useState('lejer');

  // Sistem Notifikasi Ringkas
  const [notification, setNotification] = useState(null);

  const showNotification = (message, type = 'success') => {
    setNotification({ message, type });
    setTimeout(() => setNotification(null), 3000);
  };

  // --- TINDAKAN (ACTIONS) ---

  // Tambah Transaksi
  const handleAddTransaction = (e) => {
    e.preventDefault();
    const parsedAmount = parseFloat(txAmount);

    if (!txDesc.trim() || isNaN(parsedAmount) || parsedAmount <= 0) {
      showNotification('Sila pastikan Keterangan dan Jumlah RM dimasukkan dengan betul.', 'error');
      return;
    }

    const newTx = {
      id: 'tx-' + Date.now(),
      date: txDate,
      ledgerId: txLedgerId,
      description: txDesc.trim(),
      amount: parsedAmount
    };

    setTransactions([newTx, ...transactions]);
    setTxDesc('');
    setTxAmount('');
    showNotification(`Berjaya merekod transaksi ke dalam ${LEDGERS[txLedgerId].name}!`);
  };

  // Padam Transaksi ("Buang")
  const handleDeleteTransaction = (id, ledgerName) => {
    setTransactions(transactions.filter(t => t.id !== id));
    showNotification(`Transaksi daripada ${ledgerName} telah dibuang.`);
  };

  // --- FORMULA & PENGIRAAN P&L (LIVE-LINKED) ---

  // 1. Kira jumlah terkumpul bagi setiap 4 lejer secara dinamik
  const ledgerTotals = useMemo(() => {
    const totals = { jualan: 0, belian: 0, hasil: 0, belanja: 0 };
    transactions.forEach(t => {
      if (totals[t.ledgerId] !== undefined) {
        totals[t.ledgerId] += t.amount;
      }
    });
    return totals;
  }, [transactions]);

  // 2. Formulasi untuk Penyata Untung Rugi (P&L)
  const pnlSummary = useMemo(() => {
    const totalJualan = ledgerTotals.jualan;
    const totalHasilLain = ledgerTotals.hasil;
    const totalPendapatan = totalJualan + totalHasilLain;

    const totalBelian = ledgerTotals.belian;
    const untungKasar = totalPendapatan - totalBelian;

    const totalBelanja = ledgerTotals.belanja;
    const untungBersih = untungKasar - totalBelanja;

    return {
      totalJualan,
      totalHasilLain,
      totalPendapatan,
      totalBelian,
      untungKasar,
      totalBelanja,
      untungBersih
    };
  }, [ledgerTotals]);

  // Transaksi yang ditapis untuk paparan jadual
  const filteredTransactions = useMemo(() => {
    if (selectedLedgerFilter === 'semua') return transactions;
    return transactions.filter(t => t.ledgerId === selectedLedgerFilter);
  }, [transactions, selectedLedgerFilter]);

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 font-sans pb-12 print:bg-white print:pb-0">
      
      {/* 1. HEADER (Sembunyikan sewaktu cetak) */}
      <header className="bg-gradient-to-r from-indigo-900 to-slate-900 text-white shadow-md print:hidden">
        <div className="max-w-7xl mx-auto px-4 py-6 sm:px-6 flex flex-col sm:flex-row justify-between items-center gap-4">
          <div className="flex items-center space-x-3">
            <div className="bg-indigo-600 p-2 rounded-xl shadow-inner text-white">
              <FileSpreadsheet className="h-6 w-6" />
            </div>
            <div>
              <h1 className="text-xl sm:text-2xl font-bold tracking-tight">Sistem Lejer Terpaut P&L</h1>
              <p className="text-xs text-indigo-200">Sistem Simulasi Kewangan 4 Lejer untuk Usahawan & Pelajar</p>
            </div>
          </div>
          
          {/* Petunjuk Status Ringkas */}
          <div className="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl px-4 py-1.5 text-center">
            <p className="text-[10px] text-indigo-200 font-semibold uppercase tracking-wider">Status Simulasi</p>
            <p className="text-xs font-bold text-emerald-400 flex items-center justify-center gap-1.5 mt-0.5">
              <span className="h-2 w-2 rounded-full bg-emerald-400 animate-pulse"></span>
              Live & Terhubung ke P&L
            </p>
          </div>
        </div>
      </header>

      {/* 2. RUMUSAN PRESTASI (Sembunyikan sewaktu cetak) */}
      <section className="max-w-7xl mx-auto px-4 mt-6 print:hidden">
        {/* Notifikasi Terapung */}
        {notification && (
          <div className={`mb-4 p-4 rounded-xl flex items-center gap-3 shadow-sm border transition-all duration-300 ${
            notification.type === 'error' 
              ? 'bg-rose-50 border-rose-200 text-rose-800' 
              : 'bg-emerald-50 border-emerald-200 text-emerald-800'
          }`}>
            <CheckCircle2 className="h-5 w-5 shrink-0" />
            <span className="text-sm font-medium">{notification.message}</span>
          </div>
        )}

        {/* 4 Kad Buku Lejer Utama */}
        <div className="grid grid-cols-2 lg:grid-cols-4 gap-4">
          
          {/* 1. Lejer Jualan */}
          <div className="bg-white p-4 sm:p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
            <div className="flex items-center justify-between mb-2">
              <span className="text-xs font-extrabold text-emerald-600 uppercase bg-emerald-50 px-2 py-0.5 rounded">
                Hasil
              </span>
              <span className="text-slate-400"><ArrowUpRight className="h-5 w-5" /></span>
            </div>
            <div>
              <p className="text-slate-500 text-xs font-semibold">Jumlah Lejer Jualan</p>
              <h3 className="text-lg sm:text-2xl font-black text-slate-900 mt-1">
                RM {ledgerTotals.jualan.toLocaleString('en-US', { minimumFractionDigits: 2 })}
              </h3>
            </div>
          </div>

          {/* 2. Lejer Belian */}
          <div className="bg-white p-4 sm:p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
            <div className="flex items-center justify-between mb-2">
              <span className="text-xs font-extrabold text-amber-600 uppercase bg-amber-50 px-2 py-0.5 rounded">
                Kos Belian
              </span>
              <span className="text-slate-400"><ArrowDownRight className="h-5 w-5" /></span>
            </div>
            <div>
              <p className="text-slate-500 text-xs font-semibold">Jumlah Lejer Belian</p>
              <h3 className="text-lg sm:text-2xl font-black text-slate-900 mt-1">
                RM {ledgerTotals.belian.toLocaleString('en-US', { minimumFractionDigits: 2 })}
              </h3>
            </div>
          </div>

          {/* 3. Lejer Hasil */}
          <div className="bg-white p-4 sm:p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
            <div className="flex items-center justify-between mb-2">
              <span className="text-xs font-extrabold text-indigo-600 uppercase bg-indigo-50 px-2 py-0.5 rounded">
                Hasil Lain
              </span>
              <span className="text-slate-400"><ArrowUpRight className="h-5 w-5" /></span>
            </div>
            <div>
              <p className="text-slate-500 text-xs font-semibold">Jumlah Lejer Hasil</p>
              <h3 className="text-lg sm:text-2xl font-black text-slate-900 mt-1">
                RM {ledgerTotals.hasil.toLocaleString('en-US', { minimumFractionDigits: 2 })}
              </h3>
            </div>
          </div>

          {/* 4. Lejer Belanja */}
          <div className="bg-white p-4 sm:p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
            <div className="flex items-center justify-between mb-2">
              <span className="text-xs font-extrabold text-rose-600 uppercase bg-rose-50 px-2 py-0.5 rounded">
                Belanja
              </span>
              <span className="text-slate-400"><ArrowDownRight className="h-5 w-5" /></span>
            </div>
            <div>
              <p className="text-slate-500 text-xs font-semibold">Jumlah Lejer Belanja</p>
              <h3 className="text-lg sm:text-2xl font-black text-slate-900 mt-1">
                RM {ledgerTotals.belanja.toLocaleString('en-US', { minimumFractionDigits: 2 })}
              </h3>
            </div>
          </div>

        </div>
      </section>

      {/* 3. MENU TAB NAVIGASI (Sembunyikan sewaktu cetak) */}
      <nav className="max-w-7xl mx-auto px-4 mt-6 print:hidden">
        <div className="flex border-b border-slate-200">
          <button
            onClick={() => setActiveTab('lejer')}
            className={`flex items-center gap-2 py-3.5 px-6 font-bold text-sm border-b-2 transition-all ${
              activeTab === 'lejer'
                ? 'border-indigo-600 text-indigo-600'
                : 'border-transparent text-slate-500 hover:text-slate-800'
            }`}
          >
            <BookOpen className="h-4.5 w-4.5" />
            Buku Lejer & Kemasukan Data
          </button>
          
          <button
            onClick={() => setActiveTab('pnl')}
            className={`flex items-center gap-2 py-3.5 px-6 font-bold text-sm border-b-2 transition-all relative ${
              activeTab === 'pnl'
                ? 'border-indigo-600 text-indigo-600'
                : 'border-transparent text-slate-500 hover:text-slate-800'
            }`}
          >
            <FileText className="h-4.5 w-4.5" />
            Penyata Untung Rugi (P&L)
            <span className="absolute -top-1 right-2 flex h-2 w-2">
              <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span className="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
          </button>
        </div>
      </nav>

      {/* 4. KANDUNGAN UTAMA */}
      <main className="max-w-7xl mx-auto px-4 mt-6">
        
        {/* ================= TAB 1: BUKU LEJER & DATA ENTRY ================= */}
        {activeTab === 'lejer' && (
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 print:hidden">
            
            {/* Ruang Masuk Maklumat Lejer */}
            <div className="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm self-start">
              <h2 className="text-base font-bold text-slate-900 mb-4 flex items-center gap-2">
                <Plus className="text-indigo-600 h-5 w-5" />
                Masukkan Maklumat Lejer
              </h2>
              
              <form onSubmit={handleAddTransaction} className="space-y-4">
                <div>
                  <label className="block text-xs font-bold text-slate-500 mb-1 uppercase tracking-wider">Pilih Lejer Sasaran</label>
                  <select
                    value={txLedgerId}
                    onChange={(e) => setTxLedgerId(e.target.value)}
                    className="w-full px-3.5 py-2.5 border border-slate-300 rounded-xl text-sm bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none font-semibold text-slate-700"
                  >
                    <option value="jualan">Lejer Jualan (Hasil)</option>
                    <option value="belian">Lejer Belian (Kos Belian)</option>
                    <option value="hasil">Lejer Hasil (Hasil Sampingan)</option>
                    <option value="belanja">Lejer Belanja (Belanja Kedai)</option>
                  </select>
                  <p className="text-[11px] text-slate-400 mt-1 italic">
                    {LEDGERS[txLedgerId].desc}
                  </p>
                </div>

                <div>
                  <label className="block text-xs font-bold text-slate-500 mb-1 uppercase tracking-wider">Tarikh Transaksi</label>
                  <div className="relative">
                    <Calendar className="absolute left-3 top-3 h-4 w-4 text-slate-400" />
                    <input
                      type="date"
                      required
                      value={txDate}
                      onChange={(e) => setTxDate(e.target.value)}
                      className="w-full pl-9 pr-3 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none font-medium"
                    />
                  </div>
                </div>

                <div>
                  <label className="block text-xs font-bold text-slate-500 mb-1 uppercase tracking-wider">Keterangan / Maklumat</label>
                  <input
                    type="text"
                    required
                    placeholder="Contoh: Jual burger, Beli roti burger, Bil api"
                    value={txDesc}
                    onChange={(e) => setTxDesc(e.target.value)}
                    className="w-full px-3.5 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                  />
                </div>

                <div>
                  <label className="block text-xs font-bold text-slate-500 mb-1 uppercase tracking-wider">Jumlah Nilai (RM)</label>
                  <div className="relative">
                    <span className="absolute left-3.5 top-2.5 text-sm font-black text-slate-400">RM</span>
                    <input
                      type="number"
                      step="0.01"
                      min="0.01"
                      required
                      placeholder="0.00"
                      value={txAmount}
                      onChange={(e) => setTxAmount(e.target.value)}
                      className="w-full pl-11 pr-3 py-2.5 border border-slate-300 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none font-bold text-slate-900"
                    />
                  </div>
                </div>

                <button
                  type="submit"
                  className="w-full bg-indigo-600 hover:bg-indigo-700 active:scale-[0.98] text-white font-bold py-3 rounded-xl transition-all text-xs sm:text-sm flex items-center justify-center gap-2 shadow"
                >
                  <Plus className="h-4.5 w-4.5" /> Masukkan & Link P&L
                </button>
              </form>
            </div>

            {/* Senarai Transaksi Lejer */}
            <div className="lg:col-span-2 bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex flex-col">
              
              {/* Filter Bar */}
              <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-5 pb-4 border-b border-slate-100">
                <div>
                  <h2 className="text-base font-bold text-slate-900">Aliran Kemasukan Lejer</h2>
                  <p className="text-xs text-slate-400 mt-0.5">Jumlah keseluruhan transaksi: {filteredTransactions.length} rekod</p>
                </div>
                
                <div className="flex items-center gap-2 bg-slate-100 p-1 rounded-xl">
                  <Filter className="h-3.5 w-3.5 text-slate-400 ml-2" />
                  <select
                    value={selectedLedgerFilter}
                    onChange={(e) => setSelectedLedgerFilter(e.target.value)}
                    className="bg-transparent border-none text-xs font-bold text-slate-600 outline-none cursor-pointer py-1 pr-2"
                  >
                    <option value="semua">Tapis: Semua Lejer</option>
                    <option value="jualan">Lejer Jualan</option>
                    <option value="belian">Lejer Belian</option>
                    <option value="hasil">Lejer Hasil</option>
                    <option value="belanja">Lejer Belanja</option>
                  </select>
                </div>
              </div>

              {/* Jadual Paparan Transaksi */}
              {filteredTransactions.length === 0 ? (
                <div className="flex-1 flex flex-col items-center justify-center py-12 text-center text-slate-400">
                  <AlertCircle className="h-10 w-10 text-slate-300 mb-2" />
                  <p className="text-sm font-semibold">Tiada rekod transaksi dijumpai.</p>
                  <p className="text-xs mt-0.5">Sila isi maklumat transaksi di borang sebelah kiri.</p>
                </div>
              ) : (
                <div className="overflow-x-auto">
                  <table className="w-full text-left text-xs sm:text-sm border-collapse">
                    <thead>
                      <tr className="border-b border-slate-200 text-slate-400 font-bold bg-slate-50/50">
                        <th className="py-2.5 px-3">Tarikh</th>
                        <th className="py-2.5 px-3">Buku Lejer</th>
                        <th className="py-2.5 px-3">Keterangan</th>
                        <th className="py-2.5 px-3 text-right">Jumlah (RM)</th>
                        <th className="py-2.5 px-3 text-center">Tindakan</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100 font-medium">
                      {filteredTransactions.map((t) => {
                        const currentLedger = LEDGERS[t.ledgerId];
                        return (
                          <tr key={t.id} className="hover:bg-slate-50/50 transition-colors">
                            <td className="py-3 px-3 whitespace-nowrap text-slate-500">{t.date}</td>
                            <td className="py-3 px-3 whitespace-nowrap">
                              <span className={`text-[11px] font-bold px-2 py-0.5 rounded-full inline-block ${
                                currentLedger.color === 'emerald' ? 'bg-emerald-50 text-emerald-700 border border-emerald-100' :
                                currentLedger.color === 'amber' ? 'bg-amber-50 text-amber-700 border border-amber-100' :
                                currentLedger.color === 'indigo' ? 'bg-indigo-50 text-indigo-700 border border-indigo-100' :
                                'bg-rose-50 text-rose-700 border border-rose-100'
                              }`}>
                                {currentLedger.name}
                              </span>
                            </td>
                            <td className="py-3 px-3 text-slate-700 font-normal max-w-[180px] truncate" title={t.description}>
                              {t.description}
                            </td>
                            <td className="py-3 px-3 text-right font-bold text-slate-950 whitespace-nowrap">
                              {t.amount.toFixed(2)}
                            </td>
                            <td className="py-3 px-3 text-center">
                              <button
                                onClick={() => handleDeleteTransaction(t.id, currentLedger.name)}
                                className="text-rose-500 hover:text-rose-700 hover:bg-rose-50 px-2 py-1.5 rounded-lg transition-colors inline-flex items-center gap-1 font-semibold text-xs"
                                title="Buang data ini"
                              >
                                <Trash2 className="h-3.5 w-3.5" />
                                <span className="hidden sm:inline">Buang</span>
                              </button>
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              )}

            </div>
          </div>
        )}

        {/* ================= TAB 2: PENYATA UNTUNG RUGI (P&L) ================= */}
        {activeTab === 'pnl' && (
          <div className="space-y-6">
            
            {/* Panel Tindakan Cetak (Sembunyikan sewaktu cetak) */}
            <div className="bg-indigo-900 text-white p-5 rounded-2xl flex flex-col md:flex-row md:items-center justify-between gap-4 print:hidden shadow-sm">
              <div className="space-y-1">
                <h3 className="font-bold text-sm sm:text-base">Penyata Untung Rugi Terjana!</h3>
                <p className="text-xs text-indigo-200 leading-relaxed max-w-2xl">
                  Sistem telah menghubungkan data transaksi daripada **4 lejer** anda secara terus ke dalam penyata akaun rasmi di bawah. Sila tekan butang **Cetak Laporan PDF** untuk mencetak versi bersih tanpa menu sistem.
                </p>
              </div>
              <button
                onClick={() => window.print()}
                className="bg-emerald-500 hover:bg-emerald-600 active:scale-[0.98] text-slate-950 font-bold py-2.5 px-5 rounded-xl transition-all text-xs sm:text-sm flex items-center justify-center gap-2 shrink-0 shadow-lg"
              >
                <Printer className="h-4.5 w-4.5" />
                Cetak Laporan PDF
              </button>
            </div>

            {/* HALAMAN DRAF PENYATA UNTUNG RUGI (DIPERSEMBAHKAN UNTUK PRINT-READY) */}
            <div className="bg-white p-6 sm:p-12 rounded-3xl border border-slate-200 shadow-md print:shadow-none print:border-none print:p-0 print:mx-auto">
              
              {/* Kepala Surat Penyata Rasmi */}
              <div className="text-center pb-6 border-b-2 border-slate-800 mb-8">
                <h1 className="text-xl sm:text-2xl font-black tracking-wider text-slate-900 uppercase">PENYATA UNTUNG RUGI</h1>
                <p className="text-xs sm:text-sm font-bold text-slate-500 mt-1 uppercase tracking-wide">RINGKASAN PRESTASI KEWANGAN PERNIAGAAN</p>
                <p className="text-[11px] font-semibold text-slate-500 mt-2">
                  Disediakan pada: {new Date().toLocaleDateString('ms-MY', { year: 'numeric', month: 'long', day: 'numeric' })}
                </p>
                <p className="text-[10px] text-slate-600 mt-1.5 bg-slate-100 print:bg-slate-50 py-0.5 px-3 rounded inline-block font-semibold">
                  STATUS INTEGRASI: AKTIF & TULIS-PADAM (LIVE-LINKED)
                </p>
              </div>

              {/* JADUAL STRUKTUR P&L INTERAKTIF */}
              <div className="space-y-6">
                
                {/* bahagian 1: hasil */}
                <div>
                  <div className="flex justify-between items-center bg-slate-900 text-white py-2 px-4 rounded-t-lg">
                    <span className="text-xs font-black uppercase tracking-wider">A) HASIL (PENDAPATAN)</span>
                    <span className="text-[11px] font-bold">Kredit (RM)</span>
                  </div>
                  
                  <div className="border-x border-b border-slate-200 divide-y divide-slate-100">
                    <div className="flex justify-between px-4 py-3 text-xs sm:text-sm text-slate-700 hover:bg-slate-50/50">
                      <span className="font-semibold text-slate-900">Lejer Jualan (Hasil Utama)</span>
                      <span className="font-bold">{pnlSummary.totalJualan.toFixed(2)}</span>
                    </div>
                    
                    <div className="flex justify-between px-4 py-3 text-xs sm:text-sm text-slate-700 hover:bg-slate-50/50">
                      <span className="font-semibold text-slate-900">Lejer Hasil (Pendapatan Sampingan/Lain)</span>
                      <span className="font-bold">{pnlSummary.totalHasilLain.toFixed(2)}</span>
                    </div>
                  </div>

                  <div className="flex justify-between items-center border-t border-slate-300 px-4 py-3 mt-1 bg-slate-50 rounded-b-lg">
                    <span className="text-xs sm:text-sm font-black text-slate-900 uppercase">JUMLAH PENDAPATAN KESELURUHAN (1)</span>
                    <span className="text-xs sm:text-sm font-black text-slate-950">
                      RM {pnlSummary.totalPendapatan.toFixed(2)}
                    </span>
                  </div>
                </div>

                {/* bahagian 2: kos jualan */}
                <div>
                  <div className="flex justify-between items-center bg-slate-900 text-white py-2 px-4 rounded-t-lg">
                    <span className="text-xs font-black uppercase tracking-wider">B) TOLAK: KOS JUALAN</span>
                    <span className="text-[11px] font-bold">Debit (RM)</span>
                  </div>
                  
                  <div className="border-x border-b border-slate-200 divide-y divide-slate-100">
                    <div className="flex justify-between px-4 py-3 text-xs sm:text-sm text-slate-700 hover:bg-slate-50/50">
                      <span className="font-semibold text-slate-900">Lejer Belian (Kos Barang Nyaga / Stok)</span>
                      <span className="font-bold">({pnlSummary.totalBelian.toFixed(2)})</span>
                    </div>
                  </div>

                  <div className="flex justify-between items-center border-t border-slate-300 px-4 py-3 mt-1 bg-slate-50 rounded-b-lg">
                    <span className="text-xs sm:text-sm font-black text-slate-900 uppercase">JUMLAH KOS JUALAN (2)</span>
                    <span className="text-xs sm:text-sm font-black text-slate-950">
                      RM ({pnlSummary.totalBelian.toFixed(2)})
                    </span>
                  </div>
                </div>

                {/* bahagian 3: untung kasar */}
                <div className="border-2 border-slate-900 rounded-xl py-3.5 px-4 flex justify-between items-center bg-slate-100 font-bold">
                  <div>
                    <span className="text-xs sm:text-sm font-black text-slate-950 uppercase block">UNTUNG KASAR (1 - 2)</span>
                    <span className="text-[10px] text-slate-500 font-medium">Jumlah Pendapatan ditolak Kos Jualan</span>
                  </div>
                  <span className={`text-sm sm:text-base font-black ${pnlSummary.untungKasar >= 0 ? 'text-emerald-700' : 'text-rose-700'}`}>
                    RM {pnlSummary.untungKasar.toFixed(2)}
                  </span>
                </div>

                {/* bahagian 4: belanja operasi */}
                <div>
                  <div className="flex justify-between items-center bg-slate-900 text-white py-2 px-4 rounded-t-lg">
                    <span className="text-xs font-black uppercase tracking-wider">C) TOLAK: BELANJA OPERASI</span>
                    <span className="text-[11px] font-bold">Debit (RM)</span>
                  </div>
                  
                  <div className="border-x border-b border-slate-200 divide-y divide-slate-100">
                    <div className="flex justify-between px-4 py-3 text-xs sm:text-sm text-slate-700 hover:bg-slate-50/50">
                      <span className="font-semibold text-slate-900">Lejer Belanja (Kos Utiliti, Gaji, Sewa, Iklan, dll)</span>
                      <span className="font-bold">({pnlSummary.totalBelanja.toFixed(2)})</span>
                    </div>
                  </div>

                  <div className="flex justify-between items-center border-t border-slate-300 px-4 py-3 mt-1 bg-slate-50 rounded-b-lg">
                    <span className="text-xs sm:text-sm font-black text-slate-900 uppercase">JUMLAH KOS BELANJA (3)</span>
                    <span className="text-xs sm:text-sm font-black text-slate-950">
                      RM ({pnlSummary.totalBelanja.toFixed(2)})
                    </span>
                  </div>
                </div>

                {/* bahagian 5: untung / rugi bersih */}
                <div className={`p-5 rounded-2xl border-2 flex justify-between items-center ${
                  pnlSummary.untungBersih >= 0 
                    ? 'bg-emerald-50 border-emerald-500 print:bg-slate-50 print:border-slate-800' 
                    : 'bg-rose-50 border-rose-500 print:bg-slate-50 print:border-slate-800'
                }`}>
                  <div>
                    <span className="text-xs sm:text-sm font-black text-slate-950 uppercase block">UNTUNG / (RUGI) BERSIH</span>
                    <span className="text-[10px] text-slate-500 font-semibold">Formula: Untung Kasar - Jumlah Kos Belanja</span>
                  </div>
                  <div className="text-right">
                    <span className={`text-base sm:text-xl font-black ${
                      pnlSummary.untungBersih >= 0 ? 'text-emerald-700 print:text-slate-950' : 'text-rose-700 print:text-slate-950'
                    }`}>
                      RM {pnlSummary.untungBersih.toLocaleString('en-US', { minimumFractionDigits: 2 })}
                    </span>
                  </div>
                </div>

              </div>

              {/* Ruang Tandatangan / Pengesahan bagi Laporan Bercetak */}
              <div className="hidden print:grid grid-cols-2 gap-12 mt-20 pt-10 border-t border-dashed border-slate-300 text-center">
                <div>
                  <p className="text-xs font-bold text-slate-400 uppercase">Disediakan Oleh:</p>
                  <div className="h-16"></div>
                  <p className="text-xs font-bold text-slate-900 border-t border-slate-400 pt-2 inline-block px-12">Peserta Bengkel</p>
                </div>
                <div>
                  <p className="text-xs font-bold text-slate-400 uppercase">Disahkan Oleh:</p>
                  <div className="h-16"></div>
                  <p className="text-xs font-bold text-slate-900 border-t border-slate-400 pt-2 inline-block px-12">Penyelia Bengkel</p>
                </div>
              </div>

            </div>

          </div>
        )}

      </main>

    </div>
  );
}

